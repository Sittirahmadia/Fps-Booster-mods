{
  "schemaVersion": 1,
  "id": "fpsbooster",
  "version": "${version}",
  "name": "FPS Booster",
  "description": "Lightweight FPS optimization mod for Minecraft 1.21. Optimized for low-end devices.",
  "authors": ["ArgonClient"],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.fpsbooster.FpsBoosterMod"
    ]
  },
  "mixins": [
    "fpsbooster.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.11",
    "minecraft": "~1.21",
    "java": ">=21",
    "fabric-api": "*"
  }
}
